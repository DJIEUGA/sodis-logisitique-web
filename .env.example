# Submission target: webhook (default) or airtable
VITE_SUBMISSION_TARGET=webhook

# Webhook mode
VITE_ORDER_WEBHOOK_URL=https://httpbin.org/post

# Airtable mode
# VITE_SUBMISSION_TARGET=airtable
# VITE_AIRTABLE_API_KEY=patxxxxxxxxxxxxxxxx
# VITE_AIRTABLE_BASE_ID=appxxxxxxxxxxxxxx
# VITE_AIRTABLE_TABLE_NAME=Orders
# Optional strict field mapping override (must include every key)
# VITE_AIRTABLE_FIELD_MAP_JSON={"orderId":"Order Ref","date":"Order Date","warehouse":"Pickup Hub","destination":"Destination","deliveryType":"Delivery Type","senderFullName":"Sender Name","senderPhone":"Sender Phone","senderEmail":"Sender Email","receiverFullName":"Receiver Name","receiverPhone":"Receiver Phone","receiverAddress":"Receiver Address","receiverCity":"Receiver City","itemsJson":"Items JSON","notes":"Notes","createdAt":"Created At"}
